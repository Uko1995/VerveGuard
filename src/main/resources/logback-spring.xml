<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Spring Boot default configuration location -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml" />

    <!-- Define log file paths -->
    <property name="LOG_FILE_DIR" value="logs" />
    <property name="LOG_FILE_NAME" value="verveguard" />

    <!-- Console Appender (existing runtime logging) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- File Appender (new - general logs) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE_DIR}/${LOG_FILE_NAME}.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <!-- Daily rollover with 30 days retention -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE_DIR}/${LOG_FILE_NAME}-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>10GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- Transaction-specific Appender (fraud detection logs) -->
    <appender name="TRANSACTION_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE_DIR}/transactions.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [traceId=%X{traceId}] %-5level %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE_DIR}/transactions-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>5GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- Performance/Audit Appender -->
    <appender name="AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE_DIR}/audit.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [traceId=%X{traceId}] %-5level %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE_DIR}/audit-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>5GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- Logger for TransactionService (sends to both console and transaction file) -->
    <logger name="com.example.VerveGaurd.service.TransactionService" level="DEBUG">
        <appender-ref ref="TRANSACTION_FILE" />
    </logger>

    <!-- Logger for PerformanceAspect (audit logs) -->
    <logger name="com.example.VerveGaurd.audit.PerformanceAspect" level="INFO">
        <appender-ref ref="AUDIT_FILE" />
    </logger>

    <!-- Logger for PerformanceInterceptor (request logs) -->
    <logger name="com.example.VerveGaurd.audit.PerformanceInterceptor" level="INFO">
        <appender-ref ref="AUDIT_FILE" />
    </logger>

    <!-- Spring Security logging -->
    <logger name="org.springframework.security" level="DEBUG" />
    <logger name="org.springframework.web" level="DEBUG" />

    <!-- Root Logger (everything else) -->
    <root level="WARN">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>

</configuration>

